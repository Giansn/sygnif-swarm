# Copy to swarm_operator.env (gitignored). Loaded after repo .env with override=True.
#
# === Feste Verdrahtung: systemd ``sygnif-swarm-predict-loop.service`` (automatisierte Demo-Trades) ===
# 1) Uncomment and set keys + ACK (ACK = explizites OK für echte ``--execute``-Orders auf api-demo):
# SYGNIF_PREDICT_PROTOCOL_LOOP_ACK=YES
# BYBIT_DEMO_API_KEY=
# BYBIT_DEMO_API_SECRET=
# 1b) Swarm ``btc_future`` / ``bf`` on Bybit API demo (parity with Docker ``SYGNIF_SWARM_BTC_FUTURE`` default):
# SYGNIF_SWARM_BTC_FUTURE=1
# Optional: launcher risk bundle (``scripts/swarm_auto_predict_protocol_loop.py`` / systemd wrapper):
# SYGNIF_SWARM_RISK_PROFILE=demo_safe
#
# Swarm gate: Freqtrade-style ORB + swing confluence (``orb_long`` / ``sygnif_swing`` analogs on 5m live fit):
# SWARM_ORDER_SYGNIF_STRATEGY_GUIDELINES=1
# SWARM_ORDER_GUIDELINE_TA_SPLIT_LONG=50
# SWARM_ORDER_GUIDELINE_TA_SPLIT_SHORT=50
# SYGNIF_GUIDELINE_ORB_MINUTES=30
# SYGNIF_GUIDELINE_ORB_MIN_RANGE_PCT=0.05
# When strict ORB/swing fails: allow entry if Hivemind explore is live + enhanced label aligns (see swarm_order_gate):
# SWARM_ORDER_GUIDELINE_HIVEMIND_FUSION=1
# When Truthcoin explore is down: allow guideline pass if live logreg + enhanced label align (same ML conf floor).
# SWARM_ORDER_GUIDELINE_HIVEMIND_UNREACHABLE_ML=1
# SYGNIF_GUIDELINE_HM_MIN_MARKETS=1
#
# Hivemind explore JSON: merge public Bybit ticker (liq proxy = spread_bps, vol, OI, 24h %%) into Truthcoin snapshot.
# SYGNIF_SWARM_HIVEMIND_BYBIT_PUBLIC_TICKER=0   # 0 = never fetch ticker unless SYGNIF_SWARM_BYBIT_MAINNET=1
# SYGNIF_SWARM_HIVEMIND_BYBIT_VOTE_FALLBACK=0   # 0 = hm vote only from Truthcoin voting slots (no 24h-direction fill-in)
# SYGNIF_SWARM_HIVEMIND_BYBIT_PCT_THR=0.35      # min |24h %%| for Bybit fallback hm vote (percent points)
#
# Finance-agent HTTP pull + optional persist (``GET /sygnif/swarm`` — same as ``/webhook/swarm``):
#   curl -sS -H "Authorization: Bearer $SYGNIF_SWARM_WEBHOOK_TOKEN" http://127.0.0.1:8091/sygnif/swarm
# POST ``{"persist":true}`` refreshes ``prediction_agent/swarm_knowledge_output.json`` on the host volume.
# SYGNIF_SWARM_WEBHOOK_TOKEN=
# Host helper (loads token from the same paths as compose ``env_file``; never prints the token):
#   ~/SYGNIF/scripts/swarm_webhook_pull.sh
#   ~/SYGNIF/scripts/swarm_webhook_pull.sh --persist
#
# Exchange generic ingest (``notification-handler`` :8089) — append-only JSONL audit log:
#   SYGNIF_EXCHANGE_WEBHOOK_TOKEN=   # openssl rand -hex 32
#   curl -sS -X POST http://127.0.0.1:8089/webhook/exchange \\
#     -H "Authorization: Bearer $SYGNIF_EXCHANGE_WEBHOOK_TOKEN" -H "Content-Type: application/json" \\
#     -d '{"exchange":"bybit","event":"forwarded","data":{}}'
#
# --- trade-overseer ↔ BTC futures + Swarm (Docker sets most of this; host overrides here) ---
# SYGNIF_OVERSEER_INSTANCE=futures          # poll only ``freqtrade-futures`` REST (BTC demo live)
# OVERSEER_INCLUDE_SWARM_SNAPSHOT=1         # inject ``swarm_knowledge_output.json`` line into overseer prompts
# OVERSEER_ENSURE_SWARM_GATE=0               # 1 = block overseer ``forceenter`` long when Swarm bearish / low mean
# OVERSEER_ENSURE_SWARM_MIN_MEAN=-0.25       # used with gate=1
#
# Refresh ``swarm_knowledge_output.json`` on the host (safe env parse; overseer + dashboards):
#   python3 ~/SYGNIF/scripts/refresh_swarm_knowledge_output.py
# 2) Optional: nach Nautilus training/sidecar automatisch Fusion + Swarm-JSON schreiben:
# NAUTILUS_SWARM_HOOK=1
# NAUTILUS_SWARM_HOOK_KNOWLEDGE=1
# 3) Install: sudo cp systemd/sygnif-swarm-predict-loop.service /etc/systemd/system/ && sudo systemctl daemon-reload
#    sudo systemctl enable --now sygnif-swarm-predict-loop
# Siehe INSTANCE_SETUP.md → Abschnitt „Swarm predict loop (systemd)“.
#
# Direkte Market-Orders aus ``swarm_knowledge`` (``post_linear_market_order`` / ``--market-order``; eigener ACK):
# SYGNIF_SWARM_KNOWLEDGE_ORDER_ACK=YES
#
# One-shot demo order gated on btc_future + fusion (wrapper):
#   ./scripts/swarm_btc_future_demo_order.sh
#   SYGNIF_SWARM_PREDICT_ORDER_ACK=YES ./scripts/swarm_btc_future_demo_order.sh --execute

# --- Nautilus research ↔ prediction protocol (fusion sidecar; no extra orders) ---
# Liquidation tape → fusion sidecar (``SYGNIF_PREDICT_LIQUIDATION_TAPE=1`` + ``bybit_stream_monitor`` snapshot):
# SYGNIF_PREDICT_LIQUIDATION_TAPE=1
# SYGNIF_LIQUIDATION_TAPE_WINDOW_SEC=900
# SWARM_ORDER_LIQUIDATION_TAPE_GATE=1
#
# NAUTILUS_SWARM_HOOK=1                 # after nautilus_lab training_feed / sidecar JSON writes
# NAUTILUS_SWARM_HOOK_KNOWLEDGE=1       # also refresh prediction_agent/swarm_knowledge_output.json
# SYGNIF_PROTOCOL_FUSION_SYNC=1         # btc_predict_protocol_loop: write_fused_sidecar each iter (dry-run ok)
# SYGNIF_PROTOCOL_FUSION_TICK=1         # embed loop predict line into swarm_nautilus_protocol_sidecar.json
#
# Dauerhafter Bybit-WS-Tape (Snapshot für trade_dataflow / system_snapshot.html):
#   sudo systemctl enable --now bybit-stream-monitor   # siehe systemd/bybit-stream-monitor.service
#   Public-Liquidations-WS: ``BYBIT_WS_LIQUIDATION=1`` (default), ``BYBIT_WS_LIQUIDATION_SYMBOLS=BTCUSDT,ETHUSDT``
# Optional: SYGNIF_BYBIT_WS_LOCK_FILE=/path/to/custom.lock  (default: /run/user/$UID/sygnif-bybit-ws-tape.lock)
#
# Open positions in Swarm JSON: **Bybit** ``position/list`` only (not Freqtrade/SQLite).
# SYGNIF_SWARM_OPEN_TRADES_BYBIT_SYMBOLS=BTCUSDT,ETHUSDT
# SYGNIF_SWARM_OPEN_TRADES_BYBIT_CACHE_SEC=60
# Legacy Freqtrade report: ``swarm_open_trades_freqtrade_archive.build_open_trades_report_freqtrade_legacy``
#
# Predict loop (``btc_predict_protocol_loop.py``): hedge + $fee floor + hold-until-green + trailing + swing-failure
# (defaults set in ``swarm_auto_predict_protocol_loop.py`` — override here)
# SYGNIF_PREDICT_ENSURE_HEDGE_MODE=1            # POST switch-mode hedge once (needs empty book / Bybit rules)
# SYGNIF_PREDICT_PER_TRADE_COST_USDT=1         # modeled-edge gate: floor += fee when EDGE_PLUS_FEE on
# SYGNIF_PREDICT_EDGE_PLUS_FEE=1               # 0 = floor = min edge only (no +fee)
# SYGNIF_PREDICT_MIN_EDGE_PROFIT_USDT=9       # swarm_auto default; 0 = disable modeled-edge open gate
# SWARM_ORDER_ML_LOGREG_MIN_CONF=59           # fusion embedded ML logreg confidence floor (0–100); swarm_auto default
# SYGNIF_PREDICT_EDGE_VOL_RELAX=1             # 0 = use base floor only; 1 = relax floor when move_pct is high
# SYGNIF_PREDICT_EDGE_VOL_REF_LO_PCT=0.05
# SYGNIF_PREDICT_EDGE_VOL_REF_HI_PCT=0.35
# SYGNIF_PREDICT_EDGE_VOL_RELAX_MAX=0.5
# SYGNIF_PREDICT_EDGE_VOL_RELAX_MIN_FACTOR=0.25
# SYGNIF_PREDICT_ENTRY_EXECUTION=market       # or limit_postonly — PostOnly limit resting entry (no instant position)
# SYGNIF_PREDICT_ENTRY_LIMIT_OFFSET_BPS=5
# SYGNIF_PREDICT_ENTRY_PRICE_TICK=0.1
# SYGNIF_PREDICT_ENTRY_PRICE_DECIMALS=2
# SYGNIF_PREDICT_ENTRY_LIMIT_FILL_WAIT_SEC=4
# SYGNIF_PREDICT_ENTRY_LIMIT_FALLBACK_MARKET=1
# SYGNIF_PREDICT_HOLD_UNTIL_PROFIT=1           # block opposite close + aligned refresh until uPnL ≥ min
# SYGNIF_PREDICT_MIN_UPNL_TO_CLOSE_USDT=       # unset → max(eps, PER_TRADE_COST)
# SYGNIF_PREDICT_TRAIL_MOVE_USDT=55            # swarm_auto default; after min uPnL: one-shot trailing (≈ USDT/qty); 0=off
# SYGNIF_PREDICT_SWING_FAILURE_ENTRIES=1       # decide_side tie-break from 48-bar SF pattern in live fit JSON
#
# Bybit predict loop: Freqtrade-**inspired** mechanics (no Freqtrade runtime; see swarm_bybit_ft_mechanics.py)
# SWARM_BYBIT_FT_MECHANICS=1                    # default on; set 0 to disable cooldown/fail-cap
# SWARM_BYBIT_ENTRY_COOLDOWN_SEC=120            # min seconds between successful opens (swarm_auto default 120; 0=off)
# SWARM_BYBIT_MAX_CONSEC_OPEN_FAILS=0           # block opens after N consecutive open retCode!=0 (0=off)
# SWARM_BYBIT_FT_STATE_JSON=                    # optional override; default prediction_agent/swarm_bybit_ft_state.json
#
# USDT TP/SL fallback + trail (``swarm_auto`` defaults ~600/360 TP/SL, ``SYGNIF_PREDICT_TRAIL_MOVE_USDT``=55, min uPnL 40):
# SYGNIF_SWARM_TP_USDT_TARGET=600
# SYGNIF_SWARM_SL_USDT_TARGET=360
# SYGNIF_SWARM_TPSL_PROFILE=reward_risk
# SYGNIF_PREDICT_TRAIL_MOVE_USDT=55
# SYGNIF_PREDICT_MIN_UPNL_TO_CLOSE_USDT=40
#
# Demo TP/SL apply (``finance_agent/swarm_btc_future_tpsl_apply.py``) — SL vs venue ``liqPrice`` + JSONL memory:
# SYGNIF_SWARM_SL_LIQ_ANCHOR=1              # default on: floor/cap SL vs liquidation ± buffer
# SYGNIF_SWARM_SL_LIQ_BUFFER_BPS=8        # basis points cushion beyond liqPrice
# SYGNIF_SWARM_SL_MEMORY=1                # default on: append ``prediction_agent/swarm_sl_liquidation_memory.jsonl``
# SYGNIF_SWARM_SL_MEMORY_MAX_LINES=2000
#
# Swarm order gates (see finance_agent/swarm_order_gate.py):
# SWARM_ORDER_MIN_MEAN_LONG=-0.5              # swarm_auto default; bare loop uses gate default -0.25; stricter: 0
# SWARM_ORDER_MAX_MEAN_SHORT=0.25             # symmetric short ceiling (library default 0 = mean must be <= 0)
# SWARM_ORDER_REQUIRE_NAUTILUS_NOT_CONTRARY=1   # block long if Nautilus vote is short (default in swarm_* launchers)
# SWARM_ORDER_NAUTILUS_MAX_AGE_MIN=180          # reject stale nautilus_strategy_signal (minutes)
# SWARM_ORDER_FUSION_REQUIRE_STRONG=1         # only strong_long / strong_short fusion labels
# SWARM_ORDER_ML_LOGREG_MIN_CONF=65             # require direction_logistic label+confidence on embedded ML JSON
# SYGNIF_PREDICT_LOGREG_BYPASS_MIN_CONF=0       # e.g. 70: if Swarm blocks entry but LogReg conf≥N% and label matches target, allow open (0=off)
#
# Bitcoin Core JSON-RPC (optional on-chain reads; see finance_agent/btc_rpc_client.py, scripts/btc_node_rpc_probe.py)
# BITCOIN_RPC_URL=http://127.0.0.1:8332
# BITCOIN_RPC_COOKIE_FILE=/home/ubuntu/.bitcoin/.cookie
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=
# BITCOIN_RPC_WALLET=                      # multi-wallet only: adds /wallet/<name>
# BITCOIN_RPC_SSL=0

# Predict protocol: FRED broad USD vs BTC (``usd_btc_macro`` in fusion sidecar; optional entry gate)
# FRED_API_KEY=                                 # free key; pull_btc_context writes btc_usd_index_correlation.json
# SYGNIF_PREDICT_USD_BTC_CORR_LIVE=0            # 1 = refresh from FRED in write_fused_sidecar (TTL below)
# SYGNIF_PREDICT_USD_BTC_CORR_TTL_SEC=3600
# SYGNIF_PREDICT_USD_BTC_CORR_WRITE_SNAPSHOT=0  # 1 = persist live result to btc_usd_index_correlation.json
# SYGNIF_PREDICT_USD_BTC_MACRO_OFF=0            # 1 = omit usd_btc_macro from sidecar entirely
# SWARM_ORDER_USD_BTC_MACRO_GATE=0              # 1 = block long/short on USD surge+dump vs negative 20d corr (see swarm_order_gate)

# --- BTC Truthcoin Hivemind (Swarm) — full activation block (2026-04-17 snapshot) ---
# Start truthcoin regtest first: ~/truthcoin-regtest/start-stack.sh (RPC :6013)
# Then set all vars below. SYGNIF_SWARM_HM_VOTE_MIN_VOTING_SLOTS=0 enables liveness
# vote even on a quiet regtest (no active markets). FLAT_PASS=1 keeps gate open on vote=0.
# Identity: swarm + operator are both third-party nodes — neither owns the signal chain.
# SYGNIF_SWARM_TRUTHCOIN_DC=1
# SYGNIF_SWARM_CORE_ENGINE=hivemind
# SYGNIF_SWARM_HIVEMIND_VOTE=1
# SYGNIF_SWARM_FULL_ROOT_ACCESS=1
# SYGNIF_SWARM_HM_VOTE_MIN_VOTING_SLOTS=0
# SWARM_ORDER_REQUIRE_HIVEMIND_VOTE=1
# SWARM_ORDER_HIVEMIND_VOTE_FLAT_PASS=1
# Bee (Ethereum Swarm light node — peer-weighted vote):
# SYGNIF_SWARM_BEE_VOTE=1
# SYGNIF_SWARM_BEE_PEER_WEIGHT=1
# SYGNIF_BEE_API_URL=http://127.0.0.1:1633
# NeuroLinked brain HTTP hook (post predict-loop state each iter):
# SYGNIF_NEUROLINKED_SWARM_HOOK=1
# SYGNIF_NEUROLINKED_HTTP_URL=http://127.0.0.1:8889
#
# Bybit **mainnet** REST → NeuroLinked (``systemd/sygnif-bybit-nl-feed.service``): extra ``BYBIT_SWARM_LAYER`` /
# ``BYBIT_HIVEMIND_LAYER`` lines from ``compute_swarm()`` (Truthcoin block below should be on for hm text).
# BYBIT_NL_INCLUDE_SWARM=1
# BYBIT_NL_SWARM_INTERVAL=90
# BYBIT_NL_SWARM_FULL=0

# Portfolio authority: **0** (``swarm_auto`` default) = allow reduce-only flip/flatten when model reverses even if
# the new side is gate-blocked (stay flat until eligible). **1** = hold leg until opposite entry passes the gate.
# ``swarm_authority_protocol_loop.sh`` defaults **1** for explicit authority runs.
# SWARM_PORTFOLIO_AUTHORITY=0
# SWARM_PORTFOLIO_AUTHORITY=1
#
# Discretionary trading (theory can reverse): flip debounce / post-open close wall / hold-until-green
# SYGNIF_PREDICT_OPPOSITE_SIGNAL_CONFIRM_ITER=0
# SYGNIF_PREDICT_MIN_DISCRETIONARY_CLOSE_SEC=0
# SYGNIF_PREDICT_HOLD_UNTIL_PROFIT=0

# Live prediction JSON (btc_prediction_output): Hivemind liveness fusion (on when Truthcoin flags on)
# SYGNIF_PREDICT_HIVEMIND_FUSION=1
# SYGNIF_PREDICT_HIVEMIND_FUSION=0

# Multi-repo + Truthcoin (defaults also set by swarm_* launchers; set to 0 to disable)
# SYGNIF_INSTANCE_ROOTS_SCAN=1
# SYGNIF_INSTANCE_ROOTS_EXCLUDE=logs:intel
# SYGNIF_SWARM_EXTEND_PYTHONPATH=1
# SYGNIF_SWARM_TRUTHCOIN_DC=1
# SYGNIF_TRUTHCOIN_DC_CLI=/home/ubuntu/truthcoin-dc/target/debug/truthcoin_dc_app_cli
# SYGNIF_TRUTHCOIN_DC_RPC_PORT=6013
# SYGNIF_TRUTHCOIN_DC_ROOT=/home/ubuntu/truthcoin-dc

# Hivemind processing core (not UNIX root; host dir listing when FULL_ROOT on)
# SYGNIF_SWARM_CORE_ENGINE=hivemind
# SYGNIF_SWARM_HIVEMIND_VOTE=1
# SYGNIF_SWARM_FULL_ROOT_ACCESS=1
# SWARM_ORDER_REQUIRE_HIVEMIND_VOTE=0

# --- One-knob “improvements + Truthcoin predict fusion” (``swarm_auto`` applies ``setdefault``s; see swarm_activate_bundle.py) ---
# SYGNIF_SWARM_ACTIVATE_IMPROVEMENTS=1
#
# Hourly Swarm telemetry (no orders): ``scripts/swarm_auto_improvement_flow.py``
#   sudo cp systemd/sygnif-swarm-improvement.service systemd/sygnif-swarm-improvement.timer /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now sygnif-swarm-improvement.timer
#
# Weak-points bundle (``swarm_weak_points_solution``) in state + ``prediction_agent/swarm_weak_points_latest.json`` (default on)
# SYGNIF_SWARM_IMPROVEMENT_WEAK_POINTS=1
#
# Emit ``prediction_agent/swarm_demo_runtime_hints.json`` when weak-points recommend demo churn calmdown (default off)
# SYGNIF_SWARM_IMPROVEMENT_AUTO_DEMO_TUNING=1
#
# Predict-loop launcher: apply hints file to process env (whitelist only; default off)
# SYGNIF_SWARM_RUNTIME_HINTS_APPLY=1
#
# Whitelist keys ``swarm_demo_runtime_hints.json`` may set (clamped): ``SYGNIF_SWARM_LOOP_INTERVAL_SEC``,
# ``SWARM_BYBIT_ENTRY_COOLDOWN_SEC``, ``SYGNIF_PREDICT_MIN_DISCRETIONARY_CLOSE_SEC``,
# ``PREDICT_LOOP_REFRESH_ALIGNED_EVERY_N``, ``SYGNIF_PREDICT_OPEN_IMMEDIATE``, ``SYGNIF_PREDICT_DEFAULT_NOTIONAL_USDT``,
# ``SWARM_ORDER_NAUTILUS_MAX_AGE_MIN``, ``SWARM_ORDER_ML_LOGREG_MIN_CONF``, ``SWARM_ORDER_REQUIRE_HIVEMIND_VOTE``,
# ``SWARM_ORDER_REQUIRE_NAUTILUS_NOT_CONTRARY``, ``SWARM_ORDER_REQUIRE_FUSION_ALIGN``,
# ``SWARM_ORDER_REQUIRE_BTC_FUTURE_VOTE``, ``SWARM_BYBIT_MAX_CONSEC_OPEN_FAILS``.
