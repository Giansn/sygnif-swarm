//@version=6
strategy("SYGNIF BTC 5m", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_value=0.06, slippage=2, initial_capital=10000, max_boxes_count=500, max_labels_count=500, process_orders_on_close=true)

// ── Inputs ──
srLen    = input.int(20,    "S/R Lookback", minval=10)
fibLen   = input.int(50,    "Fib Lookback", minval=20)
zoneAtr  = input.float(0.3, "Zone Thickness (x ATR)", step=0.1)
slMul    = input.float(0.75,"SL (x ATR)", step=0.25)
maxZones = input.int(8,     "Max Zones Each Side", minval=3)
pacLen   = input.int(34,    "PAC Channel EMA", minval=10)
fastEma  = input.int(89,    "Fast EMA (trend)", minval=20)
medEma   = input.int(200,   "Medium EMA (trend)", minval=50)
scalpTP  = input.float(0.5, "Scalp TP (x ATR)", step=0.1)
scalpSL  = input.float(0.4, "Scalp SL (x ATR)", step=0.1)
tbl      = input.bool(true, "Dashboard")

// ── Indicators ──
atr    = ta.atr(14)
rsiV   = ta.rsi(close, 14)
[ml, sl, hl] = ta.macd(close, 12, 26, 9)
vr     = volume / ta.sma(volume, 20)
e50_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
htfUp  = close > e50_1h
htfDn  = close < e50_1h

// ── PAC (Price Action Channel) ──
pacH = ta.ema(high, pacLen)
pacL = ta.ema(low, pacLen)
pacC = ta.ema(close, pacLen)
emaFast = ta.ema(close, fastEma)
emaMed  = ta.ema(close, medEma)

// Trend via PAC + EMAs
trendUp = emaFast > emaMed and pacL > emaMed
trendDn = emaFast < emaMed and pacH < emaMed
trending = trendUp or trendDn

// Chop = NOT trending
sideways = not trending

// PAC pullback detection (JustUncleL concept)
abovePAC = close > pacH
belowPAC = close < pacL
insidePAC = close >= pacL and close <= pacH

// Pullback: price was outside PAC, came back in, now exits other side
wasBelow3 = ta.barssince(close < pacC) <= 3
wasAbove3 = ta.barssince(close > pacC) <= 3
pacBuySignal  = trendUp and open < pacH and close > pacH and wasBelow3
pacSellSignal = trendDn and open > pacL and close < pacL and wasAbove3

// Scalp signals in sideways: any PAC exit with candle confirmation
scalpBuy  = sideways and close > pacH and close > open and close[1] <= pacH
scalpSell = sideways and close < pacL and close < open and close[1] >= pacL

// S/R + Fib
resLvl = ta.highest(high, srLen)
supLvl = ta.lowest(low, srLen)
fibHi  = ta.highest(high, fibLen)
fibLo  = ta.lowest(low, fibLen)
fibRng = fibHi - fibLo
fib382 = fibHi - fibRng * 0.382
fib500 = fibHi - fibRng * 0.500
fib618 = fibHi - fibRng * 0.618

zt = atr * zoneAtr

// ── Zone arrays ──
var array<float> dT = array.new_float(0)
var array<float> dB = array.new_float(0)
var array<int>   dI = array.new_int(0)
var array<int>   dR = array.new_int(0)
var array<box>   dX = array.new_box(0)
var array<label> dL = array.new_label(0)
var array<float> sT2 = array.new_float(0)
var array<float> sB2 = array.new_float(0)
var array<int>   sI = array.new_int(0)
var array<int>   sR = array.new_int(0)
var array<box>   sX = array.new_box(0)
var array<label> sL2 = array.new_label(0)
var float lastDemLvl = 0.0
var float lastSupLvl = 0.0

addDem(float top, float btm, string src) =>
    array.push(dT, top)
    array.push(dB, btm)
    array.push(dI, bar_index)
    array.push(dR, 0)
    array.push(dX, box.new(bar_index, top, bar_index + 5, btm, border_color=color.green, bgcolor=color.new(color.green, 65)))
    array.push(dL, label.new(bar_index + 3, top, "D", style=label.style_label_left, color=color.new(color.green, 30), textcolor=color.white, size=size.tiny, tooltip="Demand: " + src))
    if array.size(dT) > maxZones
        array.shift(dT)
        array.shift(dB)
        array.shift(dI)
        array.shift(dR)
        box.delete(array.shift(dX))
        label.delete(array.shift(dL))

addSup(float top, float btm, string src) =>
    array.push(sT2, top)
    array.push(sB2, btm)
    array.push(sI, bar_index)
    array.push(sR, 0)
    array.push(sX, box.new(bar_index, top, bar_index + 5, btm, border_color=color.red, bgcolor=color.new(color.red, 65)))
    array.push(sL2, label.new(bar_index + 3, btm, "S", style=label.style_label_left, color=color.new(color.red, 30), textcolor=color.white, size=size.tiny, tooltip="Supply: " + src))
    if array.size(sT2) > maxZones
        array.shift(sT2)
        array.shift(sB2)
        array.shift(sI)
        array.shift(sR)
        box.delete(array.shift(sX))
        label.delete(array.shift(sL2))

// Create zones (only in trends, not sideways)
supBounce = low <= supLvl + zt and close > supLvl and close > open
if supBounce and math.abs(supLvl - lastDemLvl) > atr and trending
    addDem(supLvl + zt, supLvl - zt * 0.5, "Support")
    lastDemLvl := supLvl
resReject = high >= resLvl - zt and close < resLvl and close < open
if resReject and math.abs(resLvl - lastSupLvl) > atr and trending
    addSup(resLvl + zt * 0.5, resLvl - zt, "Resistance")
    lastSupLvl := resLvl
fib618b = low <= fib618 + zt and close > fib618 and close > open
if fib618b and math.abs(fib618 - lastDemLvl) > atr
    addDem(fib618 + zt, fib618 - zt * 0.5, "Fib 61.8%")
    lastDemLvl := fib618
fib382r = high >= fib382 - zt and close < fib382 and close < open
if fib382r and math.abs(fib382 - lastSupLvl) > atr
    addSup(fib382 + zt * 0.5, fib382 - zt, "Fib 38.2%")
    lastSupLvl := fib382
bodyPct = math.abs(close - open) / close * 100
if close > open and bodyPct > 0.2 and vr > 1.8 and math.abs(low - lastDemLvl) > atr and trending
    addDem(math.min(open, close), low, "Strong bull")
    lastDemLvl := low
if close < open and bodyPct > 0.2 and vr > 1.8 and math.abs(high - lastSupLvl) > atr and trending
    addSup(high, math.max(open, close), "Strong bear")
    lastSupLvl := high

// ── Update zones + detect touch ──
bool hitDemand = false
bool hitSupply = false
float bestDConf = 0.0
float bestSConf = 0.0

if array.size(dT) > 0
    for i = array.size(dT) - 1 to 0
        ztt = array.get(dT, i)
        zb = array.get(dB, i)
        zbar = array.get(dI, i)
        zret = array.get(dR, i)
        bx = array.get(dX, i)
        lb = array.get(dL, i)
        age = math.min(bar_index - zbar, 300)
        ht = (ztt - zb) / close * 100
        conf = math.min(ht * 40 + age * 0.15 + zret * 25 + (htfUp ? 12.0 : 0.0), 100.0)
        tier = conf >= 70 ? "A+" : conf >= 50 ? "A" : conf >= 30 ? "B" : "C"
        tr2 = math.round(math.max(70 - conf * 0.45, 20))
        box.set_bgcolor(bx, color.new(color.green, tr2))
        box.set_right(bx, bar_index + 5)
        label.set_x(lb, bar_index + 4)
        label.set_y(lb, ztt)
        label.set_text(lb, tier)
        label.set_tooltip(lb, "DEMAND\n" + tier + " " + str.tostring(math.round(conf, 0)) + "%\n" + str.tostring(math.round(zb, 0)) + "–" + str.tostring(math.round(ztt, 0)) + "\nRetests: " + str.tostring(zret) + "x")
        if low <= ztt and close > ztt
            array.set(dR, i, zret + 1)
        if low <= ztt and high >= zb
            hitDemand := true
            if conf > bestDConf
                bestDConf := conf
        if close < zb - atr * 2
            box.set_bgcolor(bx, color.new(color.gray, 92))
            box.set_border_color(bx, color.new(color.gray, 85))
            label.delete(lb)
            array.remove(dT, i)
            array.remove(dB, i)
            array.remove(dI, i)
            array.remove(dR, i)
            array.remove(dX, i)
            array.remove(dL, i)

if array.size(sT2) > 0
    for i = array.size(sT2) - 1 to 0
        ztt = array.get(sT2, i)
        zb = array.get(sB2, i)
        zbar = array.get(sI, i)
        zret = array.get(sR, i)
        bx = array.get(sX, i)
        lb = array.get(sL2, i)
        age = math.min(bar_index - zbar, 300)
        ht = (ztt - zb) / close * 100
        conf = math.min(ht * 40 + age * 0.15 + zret * 25 + (htfDn ? 12.0 : 0.0), 100.0)
        tier = conf >= 70 ? "A+" : conf >= 50 ? "A" : conf >= 30 ? "B" : "C"
        tr2 = math.round(math.max(70 - conf * 0.45, 20))
        box.set_bgcolor(bx, color.new(color.red, tr2))
        box.set_right(bx, bar_index + 5)
        label.set_x(lb, bar_index + 4)
        label.set_y(lb, zb)
        label.set_text(lb, tier)
        label.set_tooltip(lb, "SUPPLY\n" + tier + " " + str.tostring(math.round(conf, 0)) + "%\n" + str.tostring(math.round(zb, 0)) + "–" + str.tostring(math.round(ztt, 0)) + "\nRetests: " + str.tostring(zret) + "x")
        if high >= zb and close < zb
            array.set(sR, i, zret + 1)
        if high >= zb and low <= ztt
            hitSupply := true
            if conf > bestSConf
                bestSConf := conf
        if close > ztt + atr * 2
            box.set_bgcolor(bx, color.new(color.gray, 92))
            box.set_border_color(bx, color.new(color.gray, 85))
            label.delete(lb)
            array.remove(sT2, i)
            array.remove(sB2, i)
            array.remove(sI, i)
            array.remove(sR, i)
            array.remove(sX, i)
            array.remove(sL2, i)

// ══════════════════════════════════════════════════════════════════════════════
// DUAL MODE: Trend = zone flip, Sideways = PAC scalp
// ══════════════════════════════════════════════════════════════════════════════
isLong  = strategy.position_size > 0
isShort = strategy.position_size < 0

// Trade log
var int totalTrades = 0
var int wins = 0
var int losses = 0
var float totalPnl = 0.0
// ta.change must run every bar (not only inside a conditional)
ctClosed = ta.change(strategy.closedtrades)
if strategy.closedtrades > 0 and ctClosed > 0
    totalTrades += 1
    lp = strategy.closedtrades.profit(strategy.closedtrades - 1)
    totalPnl += lp
    if lp > 0
        wins += 1
    else
        losses += 1

// MODE 1: TREND — zone flip (bigger trades)
zoneLong  = trending and hitDemand and close > open and not isLong
zoneShort = trending and hitSupply and close < open and not isShort

if zoneLong
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", loss=atr * slMul / syminfo.mintick)
    tier = bestDConf >= 70 ? "A+" : bestDConf >= 50 ? "A" : bestDConf >= 30 ? "B" : "C"
    eTip = "TREND LONG " + tier + "\nConf: " + str.tostring(math.round(bestDConf, 0)) + "%\nSL: $" + str.tostring(math.round(atr * slMul, 0)) + "\nW/L: " + str.tostring(wins) + "/" + str.tostring(losses)
    clr = bestDConf >= 50 ? color.green : color.new(color.green, 30)
    label.new(bar_index, low - atr * 0.4, "▲" + tier, style=label.style_label_up, color=clr, textcolor=color.white, size=bestDConf >= 50 ? size.normal : size.small, tooltip=eTip)

if zoneShort
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", loss=atr * slMul / syminfo.mintick)
    tier = bestSConf >= 70 ? "A+" : bestSConf >= 50 ? "A" : bestSConf >= 30 ? "B" : "C"
    eTip = "TREND SHORT " + tier + "\nConf: " + str.tostring(math.round(bestSConf, 0)) + "%\nSL: $" + str.tostring(math.round(atr * slMul, 0)) + "\nW/L: " + str.tostring(wins) + "/" + str.tostring(losses)
    clr = bestSConf >= 50 ? color.red : color.new(color.red, 30)
    label.new(bar_index, high + atr * 0.4, "▼" + tier, style=label.style_label_down, color=clr, textcolor=color.white, size=bestSConf >= 50 ? size.normal : size.small, tooltip=eTip)

// MODE 2: SIDEWAYS — PAC pullback scalps (tighter TP/SL, smaller labels)
if scalpBuy and not isLong and sideways
    strategy.entry("ScalpL", strategy.long)
    strategy.exit("ScLX", "ScalpL", profit=atr * scalpTP / syminfo.mintick, loss=atr * scalpSL / syminfo.mintick)
    eTip = "SCALP LONG\nPAC breakout\nTP: $" + str.tostring(math.round(atr * scalpTP, 0)) + " | SL: $" + str.tostring(math.round(atr * scalpSL, 0)) + "\nRSI: " + str.tostring(math.round(rsiV, 1))
    label.new(bar_index, low - atr * 0.3, "↑sc", style=label.style_label_up, color=color.new(color.teal, 20), textcolor=color.white, size=size.tiny, tooltip=eTip)

if scalpSell and not isShort and sideways
    strategy.entry("ScalpS", strategy.short)
    strategy.exit("ScSX", "ScalpS", profit=atr * scalpTP / syminfo.mintick, loss=atr * scalpSL / syminfo.mintick)
    eTip = "SCALP SHORT\nPAC breakdown\nTP: $" + str.tostring(math.round(atr * scalpTP, 0)) + " | SL: $" + str.tostring(math.round(atr * scalpSL, 0)) + "\nRSI: " + str.tostring(math.round(rsiV, 1))
    label.new(bar_index, high + atr * 0.3, "↓sc", style=label.style_label_down, color=color.new(color.purple, 20), textcolor=color.white, size=size.tiny, tooltip=eTip)

// PAC pullback in trend (recovery after pullback into channel)
if pacBuySignal and not isLong and not zoneLong
    strategy.entry("PB_L", strategy.long)
    strategy.exit("PBX_L", "PB_L", profit=atr * 1.0 / syminfo.mintick, loss=atr * scalpSL / syminfo.mintick)
    label.new(bar_index, low - atr * 0.3, "↑pb", style=label.style_label_up, color=color.new(color.green, 40), textcolor=color.white, size=size.tiny, tooltip="PULLBACK LONG\nTrend recovery above PAC\nTP: $" + str.tostring(math.round(atr, 0)) + " | SL: $" + str.tostring(math.round(atr * scalpSL, 0)))

if pacSellSignal and not isShort and not zoneShort
    strategy.entry("PB_S", strategy.short)
    strategy.exit("PBX_S", "PB_S", profit=atr * 1.0 / syminfo.mintick, loss=atr * scalpSL / syminfo.mintick)
    label.new(bar_index, high + atr * 0.3, "↓pb", style=label.style_label_down, color=color.new(color.red, 40), textcolor=color.white, size=size.tiny, tooltip="PULLBACK SHORT\nTrend recovery below PAC\nTP: $" + str.tostring(math.round(atr, 0)) + " | SL: $" + str.tostring(math.round(atr * scalpSL, 0)))

// ── Visuals ──
// PAC channel
pU = plot(pacH, "PAC High", color.new(color.gray, 60), 1)
pL2 = plot(pacL, "PAC Low",  color.new(color.gray, 60), 1)
fill(pU, pL2, color=sideways ? color.new(color.yellow, 90) : color.new(color.gray, 95))
plot(pacC, "PAC Mid", color.new(color.red, 60), 1)

// Trend EMAs (plot title must be const string — lengths are in inputs)
plot(emaFast, "Trend EMA (fast)", color.new(color.green, 40), 2)
plot(emaMed,  "Trend EMA (slow)", color.new(color.blue, 40),  2)

// Trend background
color bg = na
if trendUp
    bg := color.new(color.green, 95)
if trendDn
    bg := color.new(color.red, 95)
if sideways
    bg := color.new(color.yellow, 97)
bgcolor(bg)

// Fib reference
plot(fib382, "Fib 38.2", color.new(color.orange, 75), 1, plot.style_stepline)
plot(fib618, "Fib 61.8", color.new(color.green, 70),  1, plot.style_stepline)

// ── Dashboard ──
if tbl and barstate.islast
    var t = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 20), border_width=1)
    pos = isLong ? "LONG" : isShort ? "SHORT" : "FLAT"
    color pc = isLong ? color.green : isShort ? color.red : color.gray
    mode = trending ? (trendUp ? "TREND UP" : "TREND DN") : "SCALP"
    color mc = trendUp ? color.green : trendDn ? color.red : color.yellow
    wr2 = totalTrades > 0 ? wins * 100.0 / totalTrades : 0.0
    color pnlC = totalPnl >= 0 ? color.green : color.red
    table.cell(t, 0, 0, "SYGNIF",    text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 1, 0, "5m BTC",    text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1, "Position",  text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, pos,         text_color=pc,          text_size=size.normal)
    table.cell(t, 0, 2, "Mode",      text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2, mode,        text_color=mc,          text_size=size.normal)
    table.cell(t, 0, 3, "Trades",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3, str.tostring(totalTrades) + " (" + str.tostring(wins) + "W " + str.tostring(losses) + "L)", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 4, "Win Rate",  text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4, str.tostring(math.round(wr2, 1)) + "%", text_color=wr2 >= 50 ? color.green : color.red, text_size=size.small)
    table.cell(t, 0, 5, "Net PnL",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5, str.tostring(math.round(totalPnl, 4)), text_color=pnlC, text_size=size.normal)
    table.cell(t, 0, 6, "Zones",     text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(array.size(dT)) + "D " + str.tostring(array.size(sT2)) + "S", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 7, "RSI/Vol",   text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(math.round(rsiV, 0)) + " | " + str.tostring(math.round(vr, 1)) + "x", text_color=color.white, text_size=size.tiny)

alertcondition(zoneLong or scalpBuy or pacBuySignal,    "SYGNIF Long",  "SYGNIF: LONG")
alertcondition(zoneShort or scalpSell or pacSellSignal, "SYGNIF Short", "SYGNIF: SHORT")
