# Copy to ``neurolinked.service.env`` (gitignored) for ``sygnif-neurolinked`` overrides.
# Loaded after ``xrp_claude_bot/.env`` and ``SYGNIF/.env`` — later wins for duplicate keys.
#
# NeuroLinked signed GETs (chat context: positions, wallet, closed-pnl):
#   mainnet = ``BYBIT_API_*`` on api.bybit.com first, even if demo keys exist (default).
#   demo    = ``BYBIT_DEMO_*`` on api-demo first.
SYGNIF_NEUROLINKED_BYBIT_SIGNED_READ=mainnet
#
# /api/chat: local Hivemind + ``swarm_knowledge`` synthesis before Haiku (defaults). Turn off cloud:
# SYGNIF_NEUROLINKED_CHAT_HAIKU=0
# SYGNIF_NEUROLINKED_CHAT_HIVEMIND_FIRST=0
#
# Orders / Swarm venue automation stay on API demo elsewhere — keep both:
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# BYBIT_DEMO_API_KEY=
# BYBIT_DEMO_API_SECRET=
#
# Optional operator flag (informational; Swarm / hedge read it elsewhere — not used for NL signed GETs):
# SYGNIF_NEUROLINKED_BYBIT_ORDER_DEMO=1
#
# Less frequent brain disk saves (default 300s in server.py) to reduce latency spikes:
# SYGNIF_NEUROLINKED_AUTO_SAVE_INTERVAL_SEC=420
#
# Simulation loop target rate (default 100). Lower (e.g. 12–20) if HTTP / dashboard stalls:
# SYGNIF_NEUROLINKED_SIM_TARGET_HZ=32
#
# /api/chat builds trading context with several Bybit signed GETs — that work runs off the
# asyncio loop (since 2026-04) so ``GET /api/sygnif/summary`` and ``sygnif chat`` stay responsive.
#
# Cap concurrent ``asyncio.to_thread`` brain I/O (POST ingest + JSON APIs). Default 12.
# SYGNIF_NEUROLINKED_MAX_CONCURRENT_BRAIN_IO=16
